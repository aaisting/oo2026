<!doctype html>
<html>
<head>
  <link rel="stylesheet" href="../styles/auto.css">

  <style>
    .autosektsioon {
      border: 1px solid #999494;
      padding: 10px;
      margin-bottom: 10px;
    }
  </style>

  <script>
    const colors = ["red", "green", "blue"]; 
    let autod = []; 

    function loo_auto_vormid() {
      const count = parseInt(document.getElementById("autoCount").value);
      const container = document.getElementById("autodContainer");
      container.innerHTML = ""; 

      for (let i = 0; i < count; i++) {
        const fieldset = document.createElement("fieldset");
        const legend = document.createElement("legend");
        legend.textContent = "Auto " + (i + 1);
        fieldset.appendChild(legend);
        const nimiLabel = document.createElement("label");
        nimiLabel.textContent = "Nimi: ";
        const nimiInput = document.createElement("input");
        nimiInput.type = "text";
        nimiInput.className = "autoNimi";
        nimiInput.value = "Auto" + (i + 1);
        fieldset.appendChild(nimiLabel);
        fieldset.appendChild(nimiInput);
        fieldset.appendChild(document.createElement("br"));
        const andmedLabel = document.createElement("label");
        andmedLabel.textContent = "asukoht igal sekundil (m): ";
        const andmedInput = document.createElement("input");
        andmedInput.type = "text";
        andmedInput.className = "autoAndmed"; 
        fieldset.appendChild(andmedLabel);
        fieldset.appendChild(andmedInput);
        fieldset.appendChild(document.createElement("br"));
        const kaigudLabel = document.createElement("label");
        kaigudLabel.textContent = "Käiguvahetused: ";
        const kaigudInput = document.createElement("input");
        kaigudInput.type = "text";
        kaigudInput.className = "autoKaigud";
        fieldset.appendChild(kaigudLabel);
        fieldset.appendChild(kaigudInput);
        container.appendChild(fieldset);
      }
    }
    class Auto {
      constructor(nimi, y, g, andmed, kaigud, color) {
        this.nimi = nimi;     
        this.y = y;           
        this.g = g;           
        this.andmed = andmed; 
        this.kaigud = kaigud; 
        this.color = color;   
      }

      joonista() {
        const g = this.g;
        g.font = "12px Arial";
        g.strokeStyle = this.color;
        g.lineWidth = 2;

        for (let i = 1; i < this.andmed.length; i++) {
          g.setLineDash([]);
          g.beginPath();
          g.moveTo(this.andmed[i-1], this.y);
          g.lineTo(this.andmed[i], this.y);
          g.stroke();
        }

        for (let j = 0; j < this.kaigud.length; j++) {
          let pos = parseFloat(this.kaigud[j]); 
          if (isNaN(pos)) continue;

          let x = this.andmed.reduce((prev, curr) => 
            Math.abs(curr - pos) < Math.abs(prev - pos) ? curr : prev
          );

          g.strokeStyle = "white";
          g.lineWidth = 4;
          g.setLineDash([6, 6]);
          g.beginPath();
          g.moveTo(x, this.y - 20);
          g.lineTo(x, this.y + 20);
          g.stroke();
          g.setLineDash([]);

    
          g.fillStyle = "black";
          g.beginPath();
          g.arc(x, this.y, 6, 0, Math.PI * 2);
          g.fill();
        }

        let viimane = this.andmed.length - 1;
        g.fillStyle = "white";
        g.fillText(this.nimi, this.andmed[viimane] + 5, this.y - 5);
      }
    }

    function joonistaGraafik() {
      const tahvel = document.getElementById("tahvel");
      const g = tahvel.getContext("2d");
      g.clearRect(0, 0, tahvel.width, tahvel.height);

      autod = [];
      const nimed = document.querySelectorAll(".autoNimi");
      const andmed = document.querySelectorAll(".autoAndmed");
      const kaigud = document.querySelectorAll(".autoKaigud");

      for (let i = 0; i < nimed.length; i++) {
        let nimi = nimed[i].value.trim();
        let a = andmed[i].value.split(",").map(x => parseFloat(x.trim()));
        let k = kaigud[i].value.split(",").map(x => x.trim()).filter(x => x !== "");

        autod.push(new Auto(
          nimi,
          50 + i * 50,  
          g,
          a,
          k,
          colors[i % colors.length]
        ));
      }
      autod.forEach(a => a.joonista());
    }

  </script>
</head>

<body>

  <label>Mitu autot teeme? </label>
  <input type="number" id="autoCount" value="3" min="1" max="10">
  <button onclick="loo_auto_vormid()">Loo vormid</button>

  <div id="autodContainer"></div>

  <button onclick="joonistaGraafik()">Joonista graafik</button>

  <br><br>

  <canvas id="tahvel" width="800" height="400" style="border:1px solid #e6e1e1;"></canvas>

</body>
</html>
